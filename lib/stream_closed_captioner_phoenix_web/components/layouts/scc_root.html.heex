<!DOCTYPE html>
<html lang="en" class="scc-root">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {csrf_meta_tag()}
    <.live_title>
      {assigns[:page_title] || "Stream CC — Closed captions for your stream"}
    </.live_title>
    {render_tags_all(assigns[:meta_tags] || %{})}
    <link rel="icon" href={~p"/images/favicon-32x32.png"} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700;12..96,800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
  </head>

  <body>
    {@inner_content}
    <script
      data-goatcounter="https://guzman.goatcounter.com/count"
      async
      src="//gc.zgo.at/count.js"
    >
    </script>
  </body>
</html>
