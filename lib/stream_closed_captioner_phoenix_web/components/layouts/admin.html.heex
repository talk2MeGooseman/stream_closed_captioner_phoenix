<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {csrf_meta_tag()}
    <.live_title suffix=" · Admin">
      {assigns[:page_title] || "Admin"}
    </.live_title>
    <link rel="icon" href={~p"/images/favicon-32x32.png"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <link rel="stylesheet" href="https://cdn.quilljs.com/1.3.7/quill.snow.css" />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js">
    </script>
  </head>

  <body class="h-full bg-gray-100" x-data="{ sideBar: false }">
    <div class="min-h-screen flex">
      <nav
        class="fixed top-0 left-0 z-20 h-full w-64 pb-10 overflow-y-auto bg-gray-900 text-white transition-transform transform md:translate-x-0"
        x-bind:class="{ '-translate-x-full': !sideBar, 'translate-x-0': sideBar }"
      >
        <div class="flex items-center gap-3 px-5 py-4 border-b border-gray-700">
          <div>
            <p class="text-sm font-bold tracking-wide">Admin Panel</p>
            <a href="/" class="text-xs text-gray-400 hover:text-gray-200">&larr; Back to app</a>
          </div>
        </div>

        <div class="px-3 py-4 space-y-0.5 text-sm">
          <p class="px-2 py-1 text-xs font-semibold text-gray-400 uppercase tracking-wider">
            Users
          </p>
          <a
            href={~p"/admin/users"}
            class="flex items-center gap-2 px-3 py-2 rounded hover:bg-gray-700 text-gray-300 hover:text-white transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 shrink-0"
              viewBox="0 0 20 20"
              fill="currentColor"
            ><path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" /></svg>
            Users
          </a>
          <a
            href={~p"/admin/user-tokens"}
            class="flex items-center gap-2 px-3 py-2 rounded hover:bg-gray-700 text-gray-300 hover:text-white transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 shrink-0"
              viewBox="0 0 20 20"
              fill="currentColor"
            ><path
              fill-rule="evenodd"
              d="M18 8a6 6 0 01-7.743 5.743L10 14l-1 1-1 1H6v2H2v-4l4.257-4.257A6 6 0 1118 8zm-6-4a1 1 0 100 2 2 2 0 012 2 1 1 0 102 0 4 4 0 00-4-4z"
              clip-rule="evenodd"
            /></svg>
            User Tokens
          </a>

          <p class="px-2 pt-3 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wider">
            Content
          </p>
          <a
            href={~p"/admin/announcements"}
            class="flex items-center gap-2 px-3 py-2 rounded hover:bg-gray-700 text-gray-300 hover:text-white transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 shrink-0"
              viewBox="0 0 20 20"
              fill="currentColor"
            ><path
              fill-rule="evenodd"
              d="M18 3a1 1 0 00-1.447-.894L8.763 6H5a3 3 0 000 6h.28l1.771 5.316A1 1 0 008 18h1a1 1 0 001-1v-4.382l6.553 3.276A1 1 0 0018 15V3z"
              clip-rule="evenodd"
            /></svg>
            Announcements
          </a>

          <p class="px-2 pt-3 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wider">
            Bits
          </p>
          <a
            href={~p"/admin/bits-balances"}
            class="flex items-center gap-2 px-3 py-2 rounded hover:bg-gray-700 text-gray-300 hover:text-white transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 shrink-0"
              viewBox="0 0 20 20"
              fill="currentColor"
            ><path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z" /><path
              fill-rule="evenodd"
              d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z"
              clip-rule="evenodd"
            /></svg>
            Bits Balances
          </a>
          <a
            href={~p"/admin/bits-transactions"}
            class="flex items-center gap-2 px-3 py-2 rounded hover:bg-gray-700 text-gray-300 hover:text-white transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 shrink-0"
              viewBox="0 0 20 20"
              fill="currentColor"
            ><path
              fill-rule="evenodd"
              d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z"
              clip-rule="evenodd"
            /></svg>
            Bits Transactions
          </a>
          <a
            href={~p"/admin/bits-balance-debits"}
            class="flex items-center gap-2 px-3 py-2 rounded hover:bg-gray-700 text-gray-300 hover:text-white transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 shrink-0"
              viewBox="0 0 20 20"
              fill="currentColor"
            ><path
              fill-rule="evenodd"
              d="M3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z"
              clip-rule="evenodd"
            /></svg>
            Balance Debits
          </a>

          <p class="px-2 pt-3 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wider">
            Transcripts
          </p>
          <a
            href={~p"/admin/transcripts"}
            class="flex items-center gap-2 px-3 py-2 rounded hover:bg-gray-700 text-gray-300 hover:text-white transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 shrink-0"
              viewBox="0 0 20 20"
              fill="currentColor"
            ><path
              fill-rule="evenodd"
              d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z"
              clip-rule="evenodd"
            /></svg>
            Transcripts
          </a>
          <a
            href={~p"/admin/messages"}
            class="flex items-center gap-2 px-3 py-2 rounded hover:bg-gray-700 text-gray-300 hover:text-white transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 shrink-0"
              viewBox="0 0 20 20"
              fill="currentColor"
            ><path
              fill-rule="evenodd"
              d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9H5v2h2V9zm8 0h-2v2h2V9zM9 9h2v2H9V9z"
              clip-rule="evenodd"
            /></svg>
            Messages
          </a>

          <p class="px-2 pt-3 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wider">
            Settings
          </p>
          <a
            href={~p"/admin/stream-settings"}
            class="flex items-center gap-2 px-3 py-2 rounded hover:bg-gray-700 text-gray-300 hover:text-white transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 shrink-0"
              viewBox="0 0 20 20"
              fill="currentColor"
            ><path
              fill-rule="evenodd"
              d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z"
              clip-rule="evenodd"
            /></svg>
            Stream Settings
          </a>
          <a
            href={~p"/admin/translate-languages"}
            class="flex items-center gap-2 px-3 py-2 rounded hover:bg-gray-700 text-gray-300 hover:text-white transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 shrink-0"
              viewBox="0 0 20 20"
              fill="currentColor"
            ><path
              fill-rule="evenodd"
              d="M7 2a1 1 0 011 1v1h3a1 1 0 110 2H9.578a18.87 18.87 0 01-1.724 4.78c.29.354.596.696.914 1.026a1 1 0 11-1.44 1.389c-.188-.196-.373-.396-.554-.6a19.098 19.098 0 01-3.107 3.567 1 1 0 01-1.334-1.49 17.087 17.087 0 003.13-3.733 18.992 18.992 0 01-1.487-2.494 1 1 0 111.79-.89c.234.47.489.928.764 1.372.417-.934.752-1.913.997-2.927H3a1 1 0 110-2h3V3a1 1 0 011-1zm6 6a1 1 0 01.894.553l2.991 5.992a.869.869 0 01.02.037l.99 1.98a1 1 0 11-1.79.895L15.383 16h-4.764l-.724 1.447a1 1 0 11-1.788-.894l.99-1.98.019-.038 2.99-5.99A1 1 0 0113 8zm-1.382 6h2.764L13 11.236 11.618 14z"
              clip-rule="evenodd"
            /></svg>
            Translate Languages
          </a>

          <p class="px-2 pt-3 pb-1 text-xs font-semibold text-gray-400 uppercase tracking-wider">
            Integrations
          </p>
          <a
            href={~p"/admin/eventsub-subscriptions"}
            class="flex items-center gap-2 px-3 py-2 rounded hover:bg-gray-700 text-gray-300 hover:text-white transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 shrink-0"
              viewBox="0 0 20 20"
              fill="currentColor"
            ><path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z" /></svg>
            EventSub Subs
          </a>
        </div>
      </nav>

      <div class="flex-1 ml-0 md:ml-64 min-h-screen flex flex-col">
        <header class="bg-white border-b border-gray-200 px-4 h-14 flex items-center justify-between sticky top-0 z-10 shadow-sm">
          <button class="md:hidden text-gray-500 hover:text-gray-700" @click.stop="sideBar = true">
            <svg
              class="w-5 h-5"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"
              />
            </svg>
          </button>
          <span class="text-sm font-semibold text-gray-800">{assigns[:page_title] || "Admin"}</span>
          <span class="text-xs text-gray-400 truncate max-w-xs">
            {if assigns[:current_user], do: assigns[:current_user].email}
          </span>
        </header>

        <main class="flex-1 p-6">
          {@inner_content}
        </main>
      </div>

      <div
        class="fixed inset-0 z-10 bg-black/40 md:hidden"
        x-show="sideBar"
        x-cloak
        @click="sideBar = false"
      >
      </div>
    </div>
  </body>
</html>
